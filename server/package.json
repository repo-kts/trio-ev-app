{
    "name": "server",
    "version": "0.1.0",
    "private": true,
    "type": "module",
    "engines": {
        "node": "20.x"
    },
    "scripts": {
        "dev": "bun --watch src/index.ts",
        "build": "tsc --noEmit",
        "bundle": "bun build src/index.ts --outfile dist/index.js --target node --format esm --external sharp --external @prisma/client --external .prisma/client --external @aws-sdk/client-s3 --external @aws-sdk/s3-request-presigner --external bcryptjs",
        "vercel-build": "prisma generate && bun run bundle",
        "start": "NODE_ENV=production bun src/index.ts",
        "lint": "eslint .",
        "typecheck": "tsc --noEmit",
        "db:generate": "prisma generate",
        "db:migrate": "prisma migrate dev",
        "db:deploy": "prisma migrate deploy",
        "db:studio": "prisma studio",
        "db:seed": "bun prisma/seed.ts"
    },
    "dependencies": {
        "@aws-sdk/client-s3": "^3.658.0",
        "@aws-sdk/s3-request-presigner": "^3.658.0",
        "@prisma/client": "^5.21.1",
        "@trio/shared": "workspace:*",
        "bcryptjs": "^2.4.3",
        "cookie-parser": "^1.4.7",
        "cors": "^2.8.5",
        "express": "^4.21.1",
        "express-rate-limit": "^7.4.1",
        "helmet": "^8.0.0",
        "jsonwebtoken": "^9.0.2",
        "multer": "^1.4.5-lts.1",
        "pino": "^9.5.0",
        "pino-http": "^10.3.0",
        "sharp": "^0.33.5",
        "slugify": "^1.6.6",
        "zod": "^3.23.8"
    },
    "devDependencies": {
        "@eslint/js": "^9.13.0",
        "@types/bcryptjs": "^2.4.6",
        "@types/bun": "^1.1.13",
        "@types/cookie-parser": "^1.4.7",
        "@types/cors": "^2.8.17",
        "@types/express": "^5.0.0",
        "@types/jsonwebtoken": "^9.0.7",
        "@types/multer": "^1.4.12",
        "@types/node": "^22.8.4",
        "eslint": "^9.13.0",
        "globals": "^15.11.0",
        "pino-pretty": "^11.3.0",
        "prisma": "^5.21.1",
        "typescript": "^5.6.3",
        "typescript-eslint": "^8.11.0"
    }
}
