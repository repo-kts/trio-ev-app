NODE_ENV=development
PORT=8001

DATABASE_URL=postgresql://postgres:postgres@localhost:5433/trio?schema=public
# Neon (prod): use the -pooler hostname for serverless
# DATABASE_URL=postgresql://USER:PASS@ep-xxx-pooler.region.aws.neon.tech/db?sslmode=require

JWT_SECRET=at_least_sixteen_chars_dev_secret
JWT_EXPIRES_IN=7d

# Comma-separated for multi-origin (e.g. client + admin)
CORS_ORIGIN=http://localhost:5173,http://localhost:5174

LOG_LEVEL=debug

# S3 / object storage
S3_REGION=ap-south-1
S3_BUCKET=trio-ev-bucket
S3_ACCESS_KEY_ID=replace_me
S3_SECRET_ACCESS_KEY=replace_me
S3_FORCE_PATH_STYLE=false
